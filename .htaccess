# ── CARU CARS — Security Rules ──────────────────────────────────────────────────
# Block direct web access to sync script, CSV feeds, and log files.
# These should only be accessed by cron/FTP, never by browsers.

# Block sync script
<Files "sync-inventory.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Block all DealerCenter CSV files
<FilesMatch "^DealerCenter_.*\.csv$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block the sync log
<Files "sync-log.txt">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Block the original Python build script if present
<Files "build-inventory.py">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Block the raw CSV feed file if present
<Files "dealercenter_feed.csv">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>
